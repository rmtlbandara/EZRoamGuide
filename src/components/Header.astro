---
const nav = [
  ["Home", "/"], ["Countries", "/countries/"], ["Cities", "/cities/"],
  ["Travel Basics", "/travel-basics/"], ["About", "/about/"], ["Contact", "/contact/"]
];
---
<a class="skip-link" href="#main-content">Skip to content</a>
<header class="site-header">
  <div class="container nav-wrap">
    <a class="brand" href="/" aria-label="EZ Roam Guide home">
      <span class="brand-mark" aria-hidden="true">EZ</span>
      <span>EZ Roam Guide</span>
    </a>
    <nav class="nav-links" aria-label="Main navigation">
      {nav.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>
  </div>
</header>
