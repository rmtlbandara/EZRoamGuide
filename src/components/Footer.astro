---
const links = [
  ["Countries", "/countries/"], ["Cities", "/cities/"], ["Travel Basics", "/travel-basics/"], ["Tools", "/tools/"], ["Search", "/search/"],
  ["About", "/about/"], ["Contact", "/contact/"], ["Privacy Policy", "/privacy-policy/"], ["Editorial Policy", "/editorial-policy/"],
  ["Terms", "/terms-of-use/"], ["Disclaimer", "/disclaimer/"], ["Cookie Policy", "/cookie-policy/"], ["Sitemap", "/sitemap/"]
];
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a class="brand" href="/"><span class="brand-mark" aria-hidden="true">EZ</span><span>EZ Roam Guide</span></a>
        <p>Practical first-day travel guidance for arriving in a new country or city with more confidence.</p>
      </div>
      <nav aria-label="Footer navigation">
        {links.map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>
    </div>
    <small>EZ Roam Guide provides general travel planning information, not official legal, immigration, medical, or safety advice. Always confirm current rules and requirements with the responsible authority before you travel.</small>
    <small>© {new Date().getFullYear()} EZ Roam Guide. All rights reserved.</small>
  </div>
</footer>
