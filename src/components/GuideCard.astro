---
import type { Guide } from "../data/site";
import { hrefFor } from "../data/site";
const { guide } = Astro.props as { guide: Guide };
---
<article class="card">
  <span class="tag">{guide.eyebrow}</span>
  <h3>{guide.title}</h3>
  <p>{guide.description}</p>
  <a class="card-link" href={hrefFor(guide)}>Read guide →</a>
</article>
