---
import type { Guide } from "../data/site";
import { hrefFor } from "../data/site";
const { guide } = Astro.props as { guide: Guide };
const searchText = [guide.title, guide.description, guide.label, guide.eyebrow, guide.quick, guide.checklist, guide.mistakes].flat().filter(Boolean).join(" ");
---
<article class="card" data-filter-card data-search-text={searchText}>
  <span class="tag">{guide.eyebrow}</span>
  <h3>{guide.title}</h3>
  <p>{guide.description}</p>
  <p class="card-meta"><span>Updated: {guide.lastUpdated}</span><span>{guide.readingTime}</span></p>
  <a class="card-link" href={hrefFor(guide)}>Read guide →</a>
</article>
