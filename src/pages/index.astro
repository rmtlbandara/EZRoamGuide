---
import BaseLayout from "../layouts/BaseLayout.astro";
import GuideCard from "../components/GuideCard.astro";
import SearchBox from "../components/SearchBox.astro";
import ToolCard from "../components/ToolCard.astro";
import { basicGuides, cityGuides, countryGuides } from "../data/site";
import { travelTools } from "../data/tools";

const featuredCountrySlugs = ["south-korea-first-24-hours", "france-first-24-hours", "australia-first-24-hours", "united-states-first-24-hours", "japan-first-24-hours", "singapore-first-24-hours"];
const featuredCountries = featuredCountrySlugs.map((slug) => countryGuides.find((guide) => guide.slug === slug)).filter(Boolean);
const featuredCitySlugs = ["seoul-arrival-guide", "paris-arrival-guide", "london-arrival-guide", "new-york-city-arrival-guide", "tokyo-arrival-guide", "dubai-arrival-guide"];
const featuredCities = featuredCitySlugs.map((slug) => cityGuides.find((guide) => guide.slug === slug)).filter(Boolean);
const latestGuideSlugs = ["south-korea-first-24-hours", "france-first-24-hours", "seoul-arrival-guide"];
const latestGuides = latestGuideSlugs.map((slug) => [...countryGuides, ...cityGuides, ...basicGuides].find((guide) => guide.slug === slug)).filter(Boolean);
const homepageToolSlugs = ["first-24-hours-travel-planner", "hotel-address-card-generator", "first-time-traveler-confidence-checker"];
const homepageTools = homepageToolSlugs.map((slug) => travelTools.find((tool) => tool.slug === slug)).filter(Boolean);
---
<BaseLayout title="EZ Roam Guide – First 24 Hours Travel Guides" description="Practical first-day travel guides for airport arrivals, transport, SIMs, money, safety, etiquette, and planning your first 24 hours abroad.">
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="eyebrow">First 24 hours travel guides</p>
        <h1>Simple Travel Guides for Your First Day in a New Place</h1>
        <p class="hero-copy">EZ Roam Guide helps international travelers understand what to do after arriving in a new country or city — from airport transport and SIM cards to money, safety, etiquette, and first-day planning.</p>
        <div class="actions">
          <a class="button" href="/countries/">Browse Country Guides</a>
          <a class="button secondary" href="/travel-basics/">Read Travel Basics</a>
        </div>
      </div>
      <div class="hero-art" aria-hidden="true">
        <svg viewBox="0 0 420 360" role="img" focusable="false">
          <defs>
            <linearGradient id="hero-card" x1="0" x2="1" y1="0" y2="1">
              <stop offset="0%" stop-color="#ffffff" />
              <stop offset="100%" stop-color="#f1f7f5" />
            </linearGradient>
            <linearGradient id="hero-globe" x1="0" x2="1" y1="0" y2="1">
              <stop offset="0%" stop-color="#dff3ee" />
              <stop offset="100%" stop-color="#b9ded5" />
            </linearGradient>
          </defs>
          <path d="M72 256 C132 198 184 286 252 205 S344 118 374 154" fill="none" stroke="#9bbdb5" stroke-width="3" stroke-linecap="round" stroke-dasharray="8 12" />
          <rect x="86" y="68" width="214" height="246" rx="28" fill="url(#hero-card)" stroke="#d9e2df" stroke-width="2" />
          <rect x="112" y="108" width="88" height="12" rx="6" fill="#087f6b" opacity=".82" />
          <rect x="112" y="138" width="142" height="10" rx="5" fill="#9bbdb5" opacity=".75" />
          <rect x="112" y="162" width="112" height="10" rx="5" fill="#d9e2df" />
          <rect x="112" y="212" width="124" height="46" rx="14" fill="#f7efe0" stroke="#e8d7b8" />
          <path d="M130 235 l10 10 22 -24" fill="none" stroke="#087f6b" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
          <circle cx="284" cy="130" r="66" fill="url(#hero-globe)" stroke="#087f6b" stroke-width="3" />
          <path d="M230 130 h108 M284 64 c-24 25 -24 108 0 132 M284 64 c24 25 24 108 0 132" fill="none" stroke="#087f6b" stroke-width="2.4" opacity=".75" />
          <path d="M244 93 c28 16 57 16 82 0 M244 167 c28 -16 57 -16 82 0" fill="none" stroke="#087f6b" stroke-width="2.4" opacity=".65" />
          <path d="M322 228 c0 30 -38 68 -38 68 s-38 -38 -38 -68 a38 38 0 1 1 76 0Z" fill="#087f6b" />
          <circle cx="284" cy="228" r="13" fill="#fbfaf6" />
          <path d="M59 100 l82 -24 -35 38 58 20 -82 24 35 -38Z" fill="#ffffff" stroke="#087f6b" stroke-width="3" stroke-linejoin="round" />
          <circle cx="66" cy="256" r="9" fill="#087f6b" />
          <circle cx="374" cy="154" r="9" fill="#f2b84b" />
        </svg>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container feature-grid">
      <div>
        <p class="eyebrow">Why EZ Roam Guide</p>
        <h2>Useful before the sightseeing begins</h2>
        <p>Most destination pages start with what to see. We start earlier: the airport exit, the first payment, the first ride, and the moment you realize your phone has no signal.</p>
        <p>There are no photo galleries, hotel promotions, or inflated “must-do” lists here. Just readable guidance designed to help you make calm decisions while tired and unfamiliar with a place.</p>
      </div>
      <ul class="plain-list">
        <li><strong>Arrival-first:</strong> practical steps in the order you need them.</li>
        <li><strong>Beginner-friendly:</strong> simple English without assuming travel experience.</li>
        <li><strong>Change-aware:</strong> clear reminders to confirm rules and prices officially.</li>
        <li><strong>Independent:</strong> no paid destination rankings or disguised booking pitches.</li>
      </ul>
    </div>
  </section>

  <section class="section alt">
    <div class="container feature-grid">
      <div>
        <p class="eyebrow">Search</p>
        <h2>Search guides and tools</h2>
        <p>Find arrival guides, travel basics, and tools for your first day abroad.</p>
      </div>
      <SearchBox id="home-search" label="Search guides and tools" buttonText="Search guides" compact />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading"><div><p class="eyebrow">Start with the country</p><h2>Popular country arrival guides</h2></div><p>Understand the broad arrival system, money, connectivity, customs, and transport before narrowing down to a city.</p></div>
      <div class="card-grid">{featuredCountries.map((guide) => <GuideCard guide={guide} />)}</div>
      <div class="actions"><a class="button secondary" href="/countries/">View all countries</a></div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-heading"><div><p class="eyebrow">Plan the transfer</p><h2>Popular city arrival guides</h2></div><p>Airport choices, first-night neighborhoods, local transport, and a low-stress plan for the hours after check-in.</p></div>
      <div class="card-grid">{featuredCities.map((guide) => <GuideCard guide={guide} />)}</div>
      <div class="actions"><a class="button secondary" href="/cities/">View all cities</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading"><div><p class="eyebrow">Build confidence</p><h2>Travel basics for first-time travelers</h2></div><p>Evergreen explanations for the decisions that repeat across borders, from getting connected to avoiding taxi scams.</p></div>
      <div class="card-grid">{basicGuides.slice(0, 6).map((guide) => <GuideCard guide={guide} />)}</div>
      <div class="actions"><a class="button secondary" href="/travel-basics/">View all travel basics</a></div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-heading"><div><p class="eyebrow">Free travel tools</p><h2>Plan your arrival day with simple travel tools</h2></div><p>Use simple travel tools to plan your arrival day, airport transport, travel documents, internet setup, money, and first-day itinerary.</p></div>
      <div class="card-grid">{homepageTools.map((tool) => <ToolCard tool={tool} />)}</div>
      <div class="actions"><a class="button secondary" href="/tools/">View all free travel tools</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading"><div><p class="eyebrow">Recently updated</p><h2>Latest guides</h2></div><p>Our latest practical reads, reviewed for clear steps and sensible first-day pacing.</p></div>
      <div class="card-grid">
        {latestGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container feature-grid">
      <div><p class="eyebrow">Your arrival, simplified</p><h2>Start where your uncertainty is</h2></div>
      <div><p>Choose a country for the big picture, a city for the airport-to-hotel plan, Travel Basics for deeper guidance, or Tools for a quick planning helper.</p><div class="actions"><a class="button" href="/countries/">Choose a country</a><a class="button secondary" href="/tools/">Open tools</a></div></div>
    </div>
  </section>
</BaseLayout>
