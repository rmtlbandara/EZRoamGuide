---
import BaseLayout from "../layouts/BaseLayout.astro";
import GuideCard from "../components/GuideCard.astro";
import ToolCard from "../components/ToolCard.astro";
import { basicGuides, cityGuides, countryGuides, site } from "../data/site";
import { travelTools } from "../data/tools";

const schema = [
  { "@context": "https://schema.org", "@type": "WebSite", name: site.name, url: site.url, description: site.description },
  { "@context": "https://schema.org", "@type": "Organization", name: site.name, url: site.url, email: site.email }
];
const latestGuideSlugs = ["airport-arrival-checklist", "best-airport-transport-new-country", "low-stress-first-day-new-city"];
const latestGuides = basicGuides.filter((guide) => latestGuideSlugs.includes(guide.slug));
---
<BaseLayout title="EZ Roam Guide | First 24 Hours Travel Guides" description="Practical first-day travel guides for airport arrivals, transport, SIMs, money, safety, etiquette, and planning your first 24 hours abroad." schema={schema}>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">First 24 hours travel guides</p>
      <h1>Simple Travel Guides for Your First Day in a New Place</h1>
      <p class="hero-copy">EZ Roam Guide helps international travelers understand what to do after arriving in a new country or city — from airport transport and SIM cards to money, safety, etiquette, and first-day planning.</p>
      <div class="actions">
        <a class="button" href="/countries/">Browse Country Guides</a>
        <a class="button secondary" href="/travel-basics/">Read Travel Basics</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container feature-grid">
      <div>
        <p class="eyebrow">Why EZ Roam Guide</p>
        <h2>Useful before the sightseeing begins</h2>
        <p>Most destination pages start with what to see. We start earlier: the airport exit, the first payment, the first ride, and the moment you realize your phone has no signal.</p>
        <p>There are no photo galleries, hotel promotions, or inflated “must-do” lists here. Just readable guidance designed to help you make calm decisions while tired and unfamiliar with a place.</p>
      </div>
      <ul class="plain-list">
        <li><strong>Arrival-first:</strong> practical steps in the order you need them.</li>
        <li><strong>Beginner-friendly:</strong> simple English without assuming travel experience.</li>
        <li><strong>Change-aware:</strong> clear reminders to confirm rules and prices officially.</li>
        <li><strong>Independent:</strong> no paid destination rankings or disguised booking pitches.</li>
      </ul>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-heading"><div><p class="eyebrow">Start with the country</p><h2>Popular country arrival guides</h2></div><p>Understand the broad arrival system, money, connectivity, customs, and transport before narrowing down to a city.</p></div>
      <div class="card-grid">{countryGuides.slice(0, 6).map((guide) => <GuideCard guide={guide} />)}</div>
      <div class="actions"><a class="button secondary" href="/countries/">View all countries</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading"><div><p class="eyebrow">Plan the transfer</p><h2>Popular city arrival guides</h2></div><p>Airport choices, first-night neighborhoods, local transport, and a low-stress plan for the hours after check-in.</p></div>
      <div class="card-grid">{cityGuides.slice(0, 6).map((guide) => <GuideCard guide={guide} />)}</div>
      <div class="actions"><a class="button secondary" href="/cities/">View all cities</a></div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-heading"><div><p class="eyebrow">Build confidence</p><h2>Travel basics for first-time travelers</h2></div><p>Evergreen explanations for the decisions that repeat across borders, from getting connected to avoiding taxi scams.</p></div>
      <div class="card-grid">{basicGuides.slice(0, 6).map((guide) => <GuideCard guide={guide} />)}</div>
      <div class="actions"><a class="button secondary" href="/travel-basics/">View all travel basics</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading"><div><p class="eyebrow">Free travel tools</p><h2>Plan your arrival day with simple travel tools</h2></div><p>Use simple travel tools to plan your arrival day, airport transport, travel documents, internet setup, money, and first-day itinerary.</p></div>
      <div class="card-grid">{travelTools.slice(0, 3).map((tool) => <ToolCard tool={tool} />)}</div>
      <div class="actions"><a class="button secondary" href="/tools/">View all free travel tools</a></div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-heading"><div><p class="eyebrow">Recently updated</p><h2>Latest guides</h2></div><p>Our latest practical reads, reviewed for clear steps and sensible first-day pacing.</p></div>
      <div class="card-grid">
        {latestGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container feature-grid">
      <div><p class="eyebrow">Your arrival, simplified</p><h2>Start where your uncertainty is</h2></div>
      <div><p>Choose a country for the big picture, a city for the airport-to-hotel plan, Travel Basics for deeper guidance, or Tools for a quick planning helper.</p><div class="actions"><a class="button" href="/countries/">Choose a country</a><a class="button secondary" href="/tools/">Open tools</a></div></div>
    </div>
  </section>
</BaseLayout>
