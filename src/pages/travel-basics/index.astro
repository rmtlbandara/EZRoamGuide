---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GuideCard from "../../components/GuideCard.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { basicGuides } from "../../data/site";
---
<BaseLayout title="Travel Basics for International Travelers | EZ Roam Guide" description="Clear travel basics for first-time international travelers: airport safety, SIMs, money, public transport, etiquette, scams, and first-day planning.">
  <Breadcrumb items={[{label:"Home",href:"/"},{label:"Travel Basics"}]} />
  <header class="page-head"><div class="container"><p class="eyebrow">Travel basics</p><h1>Skills that travel well</h1><p class="lede">Straightforward guides to the decisions that follow you across borders, written for global readers and first-time international travelers.</p></div></header>
  <section class="section"><div class="container card-grid">{basicGuides.map((guide) => <GuideCard guide={guide} />)}</div></section>
</BaseLayout>
