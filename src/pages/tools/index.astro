---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SectionFilter from "../../components/SectionFilter.astro";
import ToolCard from "../../components/ToolCard.astro";
import { toolsIntro, travelTools } from "../../data/tools";
import { absoluteUrl, breadcrumbListSchema, faqPageSchema, webPageSchema } from "../../data/schema";

const toolGroups = [
  { title: "Arrival planning tools", description: "Start with a calm plan for the first few hours after landing.", slugs: ["first-24-hours-travel-planner", "first-day-itinerary-builder", "hotel-address-card-generator", "late-night-arrival-planner"] },
  { title: "Airport and transport tools", description: "Compare practical choices before you leave the airport or walk with luggage.", slugs: ["airport-transport-helper", "airport-layover-comfort-planner", "arrival-day-walking-distance-helper"] },
  { title: "Travel preparation tools", description: "Prepare documents, chargers, packing, and first-trip readiness before you fly.", slugs: ["offline-travel-documents-checklist", "travel-adapter-charging-checklist", "first-day-packing-checklist", "first-time-traveler-confidence-checker"] },
  { title: "Internet and money tools", description: "Plan the phone setup and first-day money buffer that keep arrival day moving.", slugs: ["sim-esim-roaming-finder", "first-day-travel-money-estimator"] }
].map((group) => ({ ...group, tools: travelTools.filter((tool) => group.slugs.includes(tool.slug)) }));
const breadcrumbSchema = breadcrumbListSchema([
  { name: "Home", url: absoluteUrl("/") },
  { name: "Tools", url: absoluteUrl("/tools/") }
]);
const faqSchema = faqPageSchema(toolsIntro.faqs);
const pageSchema = webPageSchema(toolsIntro.title, toolsIntro.description, "/tools/");
---
<BaseLayout title={toolsIntro.seoTitle} description={toolsIntro.description} canonical="/tools/" schema={[breadcrumbSchema, faqSchema, pageSchema].filter(Boolean)}>
  <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Tools" }]} />
  <header class="page-head">
    <div class="container">
      <p class="eyebrow">Free travel tools</p>
      <h1>{toolsIntro.title}</h1>
      <p class="lede">{toolsIntro.intro}</p>
      <div class="meta"><span>Last updated: June 27, 2026</span><span>Quick, simple, and free to use</span></div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Choose a tool</p>
          <h2>Plan with more confidence</h2>
        </div>
        <p>Use these simple tools to plan your trip with more confidence.</p>
      </div>
      <SectionFilter targetId="tool-list" label="Filter this section" placeholder="Filter tools such as SIM, checklist, hotel address, or transport" noResults="No tool matches yet. Try a broader word such as airport, SIM, checklist, money, or first day." />
      <div id="tool-list" data-filter-scope>
      {toolGroups.map((group) => (
        <section class="tool-group" data-filter-group aria-labelledby={`group-${group.title.toLowerCase().replaceAll(" ", "-")}`}>
          <div class="tool-group-head">
            <h3 id={`group-${group.title.toLowerCase().replaceAll(" ", "-")}`}>{group.title}</h3>
            <p>{group.description}</p>
          </div>
          <div class="card-grid">
            {group.tools.map((tool) => <ToolCard tool={tool} />)}
          </div>
        </section>
      ))}
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container feature-grid">
      <div>
        <p class="eyebrow">How to use them</p>
        <h2>Use tools for decisions, guides for context</h2>
      </div>
      <div>
        <p>The tools are quick helpers for practical choices: which airport transport to use, what to save offline, how much money to prepare, or how to keep the first day light.</p>
        <p>For deeper explanation, each tool links to related Travel Basics articles so you can understand the reasoning before you travel.</p>
        <div class="actions">
          <a class="button secondary" href="/travel-basics/">Read Travel Basics</a>
          <a class="button secondary" href="/travel-basics/plan-your-first-24-hours-abroad/">Plan your first 24 hours</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container feature-grid">
      <div>
        <p class="eyebrow">Tool clusters</p>
        <h2>Match the tool to the first-day decision</h2>
      </div>
      <div class="related">
        <a href="/tools/airport-transport-helper/"><span>Plan your first airport transfer calmly →</span><small>Airport arrival and transport</small></a>
        <a href="/tools/sim-esim-roaming-finder/"><span>Choose between SIM, eSIM, roaming, or Wi-Fi →</span><small>Internet access after landing</small></a>
        <a href="/tools/first-day-travel-money-estimator/"><span>Estimate your first-day money buffer →</span><small>Cash, cards, and arrival budget</small></a>
        <a href="/tools/late-night-arrival-planner/"><span>Prepare for a late-night arrival →</span><small>Safety, scams, and calm check-in</small></a>
        <a href="/tools/hotel-address-card-generator/"><span>Create a hotel address card →</span><small>First-night stay and local basics</small></a>
        <a href="/travel-basics/">Read the related Travel Basics guides →</span><small>Deeper context for each tool</small></a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container reading faq">
      <p class="eyebrow">Questions</p>
      <h2>FAQ</h2>
      {toolsIntro.faqs.map((faq) => <details><summary>{faq.question}</summary><p>{faq.answer}</p></details>)}
    </div>
  </section>
</BaseLayout>
