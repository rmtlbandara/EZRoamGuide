---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { findGuideByHref, hrefFor, site, type Guide } from "../../data/site";
import { hrefForTool, toolUrl, travelTools, type TravelTool } from "../../data/tools";

export function getStaticPaths() {
  return travelTools.map((tool) => ({ params: { slug: tool.slug }, props: { tool } }));
}

const { tool } = Astro.props as { tool: TravelTool };
const url = toolUrl(tool);
const relatedGuides = tool.relatedGuides.map((href) => {
  const guide = findGuideByHref(href) as Guide | undefined;
  const relatedTool = travelTools.find((candidate) => hrefForTool(candidate) === href);
  return {
    href,
    title: guide?.title ?? relatedTool?.title ?? href.replaceAll("/", " ").trim(),
    meta: guide ? `Updated: ${guide.lastUpdated} · ${guide.readingTime}` : relatedTool ? `${relatedTool.category} · ${relatedTool.readingTime}` : undefined
  };
});
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: site.url },
    { "@type": "ListItem", position: 2, name: "Tools", item: new URL("/tools/", site.url).toString() },
    { "@type": "ListItem", position: 3, name: tool.title, item: url }
  ]
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: tool.faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer }
  }))
};
const appSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: tool.title,
  url,
  applicationCategory: "TravelApplication",
  operatingSystem: "Any modern device",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description: tool.description,
  publisher: { "@type": "Organization", name: site.name, url: site.url }
};
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: tool.title,
  url,
  description: tool.description
};
---
<BaseLayout title={`${tool.title} | EZ Roam Guide`} description={tool.description} canonical={hrefForTool(tool)} schema={[breadcrumbSchema, faqSchema, webPageSchema, appSchema]}>
  <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Tools", href: "/tools/" }, { label: tool.title }]} />
  <header class="page-head">
    <div class="container">
      <p class="eyebrow">{tool.category}</p>
      <h1>{tool.title}</h1>
      <p class="lede">{tool.intro}</p>
      <div class="meta"><span>Last updated: {tool.lastUpdated}</span><span>{tool.readingTime}</span><span>Ready when you need it</span></div>
    </div>
  </header>

  <div class="container tool-shell">
    <article>
      <section class="callout" aria-labelledby="how-this-tool-helps">
        <h2 id="how-this-tool-helps">How this tool helps</h2>
        <ul>{tool.howItHelps.map((item) => <li>{item}</li>)}</ul>
      </section>

      <section class="tool-card article-section" id="tool">
        <div class="tool-card-head">
          <div>
            <p class="eyebrow">Interactive tool</p>
            <h2>Choose your travel situation</h2>
          </div>
          <p>Quick, simple, and free to use.</p>
        </div>
        <p class="tool-intro">Answer a few simple questions and get a practical suggestion for your arrival day.</p>
        <aside class="note tool-privacy"><strong>Privacy note:</strong> These tools are free to use and do not require sign-up. Your answers are not saved or sent anywhere.</aside>

        <form class="tool-form" data-tool-type={tool.toolType} novalidate>
          <div class="form-grid">
            {tool.fields.map((field) => (
              field.type === "checkbox" ? (
                <fieldset class="field field-full">
                  <legend>{field.label}</legend>
                  {field.help && <p class="field-help">{field.help}</p>}
                  <div class="check-grid">
                    {field.options.map((option) => (
                      <label class="check-option">
                        <input type="checkbox" name={field.id} value={option} />
                        <span>{option}</span>
                      </label>
                    ))}
                  </div>
                </fieldset>
              ) : (
                <label class="field">
                  <span>{field.label}</span>
                  {field.type === "select" ? (
                    <select name={field.id} required={field.required}>
                      {field.options.map((option) => <option value={option} selected={option === field.defaultValue}>{option}</option>)}
                    </select>
                  ) : field.type === "number" ? (
                    <input type="number" name={field.id} value={field.defaultValue} min={field.min} step={field.step} required={field.required} />
                  ) : (
                    <input type="text" name={field.id} value={field.defaultValue} placeholder={field.placeholder} required={field.required} />
                  )}
                  {field.help && <small class="field-help">{field.help}</small>}
                </label>
              )
            ))}
          </div>
          <p class="form-message" data-form-message aria-live="polite"></p>
          <div class="actions">
            <button class="button" type="submit">{tool.buttonLabel}</button>
            <button class="button secondary" type="button" data-copy-result>{tool.toolType === "addressCard" ? "Copy Card" : "Copy Result"}</button>
            {tool.canPrint && <button class="button secondary" type="button" data-print-result>{tool.toolType === "addressCard" ? "Print Card" : "Print Checklist"}</button>}
            <button class="button secondary" type="reset" data-reset-result>Reset</button>
          </div>
        </form>

        <div class="tool-result" data-result aria-live="polite" tabindex="-1">
          <h3>Your travel planning suggestion</h3>
          <p>Choose your options and use the result as a simple starting point for your travel planning.</p>
        </div>
      </section>

      <section class="article-section">
        <h2>{tool.advice.heading}</h2>
        {tool.advice.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </section>

      <aside class="note"><strong>Planning note:</strong> This free tool gives general travel planning guidance. It does not check live prices, laws, visa rules, transport schedules, SIM availability, or local safety alerts. Confirm official information for your dates and circumstances.</aside>

      <section class="faq article-section" id="faq">
        <h2>Frequently asked questions</h2>
        {tool.faqs.map((faq) => <details><summary>{faq.question}</summary><p>{faq.answer}</p></details>)}
      </section>

      <section class="article-section" id="related">
        <h2>Related guides and tools</h2>
        <div class="related">
          {relatedGuides.map((item) => (
            <a href={item.href}>
              <span>{item.title} →</span>
              {item.meta && <small>{item.meta}</small>}
            </a>
          ))}
        </div>
      </section>
    </article>
    <aside class="toc" aria-label="Table of contents">
      <strong>On this page</strong>
      <ul>
        <li><a href="#how-this-tool-helps">How this tool helps</a></li>
        <li><a href="#tool">Interactive tool</a></li>
        <li><a href="#faq">FAQ</a></li>
        <li><a href="#related">Related guides and tools</a></li>
      </ul>
    </aside>
  </div>

  <script is:inline>
    const escapeHtml = (value) => String(value).replace(/[&<>"']/g, (char) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" }[char]));
    const titleCase = (value) => String(value || "").replace(/(^|\\s)\\S/g, (char) => char.toUpperCase());
    const listHtml = (items) => `<ul>${items.map((item) => `<li>${escapeHtml(item)}</li>`).join("")}</ul>`;
    const sectionHtml = (heading, items) => `<h3>${escapeHtml(heading)}</h3>${Array.isArray(items) ? listHtml(items) : `<p>${escapeHtml(items)}</p>`}`;
    const asMoney = (amount, currency) => `${Number(amount || 0).toLocaleString(undefined, { maximumFractionDigits: 2 })} ${String(currency || "").trim().toUpperCase()}`;
    const textFromSections = (title, sections) => [title, "", ...sections.flatMap((section) => [section.heading, ...section.items.map((item) => `- ${item}`), ""])].join("\\n").trim();
    const render = (resultEl, title, sections) => {
      resultEl.dataset.resultText = textFromSections(title, sections);
      resultEl.innerHTML = `<h3>Your travel planning suggestion</h3><p class="result-summary">${escapeHtml(title)}</p>${sections.map((section) => sectionHtml(section.heading, section.items)).join("")}<p class="result-reminder">Use this as a starting point and confirm local rules, prices, and transport details before you travel.</p>`;
      resultEl.focus({ preventScroll: true });
    };
    const get = (form, name) => new FormData(form).get(name)?.toString() || "";
    const checked = (form, name) => new FormData(form).getAll(name).map((item) => item.toString());
    const yes = (value) => value === "yes";

    function buildFirst24(form) {
      const arrival = get(form, "arrivalTime");
      const traveler = get(form, "travelerType");
      const internet = get(form, "internetStatus");
      const money = get(form, "moneyStatus");
      const accommodation = get(form, "accommodation");
      const energy = get(form, "energy");
      const late = arrival === "late night";
      const family = traveler === "family";
      const low = energy === "low";
      return {
        title: "Your first 24 hours arrival plan",
        sections: [
          { heading: "Airport exit advice", items: [late ? "Move slowly and use staffed airport areas while arranging transport." : "Clear immigration, collect bags, use the restroom, and pause before entering the arrivals hall.", family ? "Keep the group together before handling SIM, cash, or transport decisions." : "Keep passport, wallet, phone, and first-night address easy to reach."] },
          { heading: "Internet/SIM advice", items: [internet === "already have SIM/eSIM" ? "Test mobile data away from airport Wi-Fi before leaving." : internet === "need internet after landing" ? "Use official airport Wi-Fi or a verified SIM/eSIM counter, then test maps and messaging." : "Use airport Wi-Fi first, open offline documents, and decide whether roaming, eSIM, or local SIM fits the trip."] },
          { heading: "Money advice", items: [money === "have local cash" ? "Keep small notes accessible and store backup cards separately." : money === "need ATM/exchange" ? "Use a bank ATM or licensed counter for a modest first amount." : "Confirm your card works for transport and keep a backup option ready."] },
          { heading: "Transport and check-in", items: [late || accommodation === "near airport" ? "Favor official taxi, hotel transfer, airport hotel, or another direct verified option." : "Compare rail, airport bus, official taxi, and ride-hailing by the full door-to-door trip.", accommodation === "unknown" ? "Confirm your exact accommodation address before leaving the terminal." : `Use the route that best fits a ${accommodation} stay.`] },
          { heading: "Food, rest, and safety", items: [low ? "Keep the evening minimal: water, simple food, shower, charge devices, sleep." : "Add only one light nearby task after check-in if you still feel steady.", "Message a trusted person after arrival and again after check-in.", "Prepare tomorrow's first route before sleeping."] },
          { heading: "Simple checklist", items: ["Passport and bags secure", "Phone connection tested", "Small payment method ready", "Official transport chosen", "Accommodation address saved offline", "Water, food, rest, and tomorrow's route handled"] }
        ]
      };
    }

    function buildTransport(form) {
      const arrival = get(form, "arrivalTime");
      const luggage = get(form, "luggage");
      const traveler = get(form, "travelerType");
      const budget = get(form, "budget");
      const comfort = get(form, "publicComfort");
      const direct = yes(get(form, "directDrop"));
      let options = [];
      if (direct || arrival === "late night" || luggage === "heavy" || traveler === "family") options = budget === "flexible" ? ["Hotel transfer", "Private transfer", "Official taxi"] : ["Official taxi", "Ride-hailing app"];
      else if (budget === "low" && comfort === "comfortable") options = ["Train/metro", "Airport bus"];
      else if (comfort === "comfortable") options = ["Train/metro", "Airport bus", "Ride-hailing app"];
      else options = ["Official taxi", "Ride-hailing app", "Hotel transfer"];
      return {
        title: "Recommended airport transport options",
        sections: [
          { heading: "Best fit", items: options.slice(0, 2) },
          { heading: "Why this fits", items: [direct ? "You asked for direct hotel drop-off, so door-to-door options make sense." : "You can compare the full route instead of choosing only by price.", arrival === "late night" ? "Late-night arrivals reduce public transport choices, so verified road transport may be calmer." : "Your arrival time leaves more transport choices open.", luggage === "heavy" ? "Heavy luggage makes fewer transfers more valuable." : "Your luggage level leaves room for public transport if the route is simple."] },
          { heading: "Check before leaving the airport", items: ["Exact pickup point or platform", "Fare method and whether cash/card/app is needed", "Final walk from stop to accommodation", "Last service time if using public transport", "Vehicle plate or booking receipt for road transport"] },
          { heading: "What to avoid", items: ["Unofficial drivers inside the arrivals hall", "Cancelling app rides to pay outside the app", "Routes that require perfect timing", "Long unlit final walks with bags"] },
          { heading: "Decision checklist", items: ["Route verified", "Payment method ready", "Address saved offline", "Backup option chosen"] }
        ]
      };
    }

    function buildInternet(form) {
      const esim = get(form, "esim");
      const trip = get(form, "tripLength");
      const calls = yes(get(form, "calls"));
      const maps = yes(get(form, "maps"));
      const before = yes(get(form, "before"));
      const buyAfter = yes(get(form, "buyAfter"));
      let recommendation = "Use airport Wi-Fi first, then decide";
      if (esim === "yes" && before && !calls) recommendation = "Use eSIM";
      else if ((calls || trip === "more than 1 week") && buyAfter) recommendation = "Buy local SIM";
      else if (trip === "1–3 days" && !buyAfter) recommendation = "Use roaming";
      return {
        title: recommendation,
        sections: [
          { heading: "Best for whom", items: [recommendation === "Use eSIM" ? "Travelers with eSIM phones who want data ready at landing." : recommendation === "Buy local SIM" ? "Travelers staying longer or needing local calls." : recommendation === "Use roaming" ? "Short-trip travelers whose home plan has reasonable travel roaming." : "Travelers who are unsure about compatibility, pricing, or setup."] },
          { heading: "Pros", items: [recommendation === "Use eSIM" ? "Can be installed before departure and keeps the physical SIM slot free." : recommendation === "Buy local SIM" ? "May offer local calls and good longer-stay value." : recommendation === "Use roaming" ? "Keeps your normal number active with minimal setup." : "Lets you reach your hotel before making a rushed purchase."] },
          { heading: "Watch-outs", items: [esim === "not sure" ? "Confirm phone compatibility before buying an eSIM." : "Check plan validity, coverage, hotspot rules, and activation timing.", calls ? "If you need local calls, many travel eSIMs may not be enough." : "If you only need maps and messaging, data-only plans may be fine.", "Do not rely on live prices from memory; confirm current plans before buying."] },
          { heading: "Arrival-day tip", items: [maps ? "Test maps and messaging before leaving the airport." : "Confirm the apps or calls you actually need before paying.", "Keep offline documents ready in case setup takes longer than expected."] }
        ]
      };
    }

    function buildDocuments(form) {
      const selected = checked(form, "documents");
      const all = Array.from(form.querySelectorAll('input[name="documents"]')).map((input) => input.value);
      const missing = all.filter((item) => !selected.includes(item));
      return {
        title: "Your offline travel documents checklist",
        sections: [
          { heading: "Completed items", items: selected.length ? selected : ["No completed items selected yet."] },
          { heading: "Missing items", items: missing.length ? missing : ["Everything in this checklist is selected. Review file access while offline before departure."] },
          { heading: "Final preparation note", items: ["Open key files once in airplane mode to confirm they are really available offline.", "Keep sensitive files protected with a device lock and avoid saving full card numbers or passwords.", "Your selections are only used to prepare this checklist."] }
        ]
      };
    }

    function buildMoney(form) {
      const currency = get(form, "currency") || "USD";
      const values = ["transport", "meal", "sim", "small", "backup"].map((name) => Number(get(form, name) || 0));
      const [transport, meal, sim, small, backup] = values;
      const total = values.reduce((sum, item) => sum + item, 0);
      const cash = transport + meal * 0.4 + small + backup * 0.5;
      const card = Math.max(total - cash, 0);
      return {
        title: "Your first-day travel money estimate",
        sections: [
          { heading: "Total first-day estimate", items: [asMoney(total, currency)] },
          { heading: "Suggested cash portion", items: [asMoney(cash, currency), "Carry only what you can protect; smaller notes are useful for arrival day."] },
          { heading: "Suggested card portion", items: [asMoney(card, currency), "Keep a backup card separate from your main wallet."] },
          { heading: "Emergency backup reminder", items: [asMoney(backup, currency), "Do not treat this as spending money unless something changes."] },
          { heading: "Money safety tips", items: ["Use bank ATMs or licensed exchange counters.", "Read currency conversion screens before approving.", "Confirm how airport transport is paid before leaving the terminal."] }
        ]
      };
    }

    function buildLateNight(form) {
      const time = get(form, "arrivalTime");
      const alone = yes(get(form, "alone"));
      const confirmed = yes(get(form, "accommodation"));
      const transport = yes(get(form, "transport"));
      const internet = yes(get(form, "internet"));
      const cash = yes(get(form, "cash"));
      const address = yes(get(form, "address"));
      return {
        title: "Your late-night arrival plan",
        sections: [
          { heading: "Priority actions", items: [confirmed ? "Keep check-in details open and tell the property if delayed." : "Confirm accommodation before leaving the airport if possible.", transport ? "Use your booked transport and verify driver or vehicle details." : "Use an official taxi, hotel transfer, airport hotel, or staffed transport desk.", internet ? "Test messaging and maps before leaving airport Wi-Fi." : "Connect to official airport Wi-Fi and open offline details first."] },
          { heading: "Things to avoid", items: ["Changing hotels because an unsolicited driver suggests it", "Following unofficial offers away from staffed areas", "Taking a long orientation walk after arrival", time === "after midnight" ? "Depending on public transport without confirming it still operates" : "Assuming evening services run as frequently as daytime services"] },
          { heading: "Safety checklist", items: [alone ? "Share arrival and check-in updates privately with a trusted person." : "Keep the group together until check-in.", cash ? "Keep small cash accessible and the rest secure." : "Confirm card or app payment before entering a vehicle.", address ? "Show the saved address if needed." : "Save the hotel address offline before leaving the terminal."] },
          { heading: "Emergency preparation reminder", items: ["Know the local emergency number.", "Move toward airport staff, police, airline counters, or hotel reception if something feels wrong.", "Confirm official information for your destination and date."] }
        ]
      };
    }

    function buildPacking(form) {
      const selected = checked(form, "items");
      const must = ["Documents", "Phone and charger", "Local cash or card", "Medication", "Hotel address", "Transport details"].filter((item) => selected.includes(item));
      const nice = selected.filter((item) => !must.includes(item));
      const carry = ["Documents", "Phone and charger", "Power bank", "Local cash or card", "Medication", "Hotel address", "Transport details", "Change of clothes"].filter((item) => selected.includes(item));
      return {
        title: "Your first-day packing mini checklist",
        sections: [
          { heading: "Must-have items", items: must.length ? must : ["Documents, payment, phone power, medication, hotel address, and transport details should be considered must-haves."] },
          { heading: "Nice-to-have items", items: nice.length ? nice : ["No nice-to-have items selected yet."] },
          { heading: "Keep in carry-on", items: carry.length ? carry : ["Keep essential documents, medicine, payment, phone, and first-night details in cabin baggage."] },
          { heading: "Avoid relying on checked luggage for", items: ["Passport or entry documents", "Essential medication", "Payment cards or emergency cash", "Phone charger or power bank where airline rules allow", "First-night address and transport details"] }
        ]
      };
    }

    function buildItinerary(form) {
      const arrival = get(form, "arrivalTime");
      const checkin = get(form, "checkin");
      const energy = get(form, "energy");
      const confidence = get(form, "transportConfidence");
      const activity = yes(get(form, "activity"));
      const rest = yes(get(form, "rest"));
      const light = energy === "low" || rest || arrival === "late night";
      return {
        title: "Your low-stress first-day itinerary",
        sections: [
          { heading: "Airport arrival", items: ["Clear immigration, collect bags, use the restroom, and confirm phone/payment basics before leaving.", confidence === "not comfortable" ? "Choose a verified direct transport option if the route feels unclear." : "Use the route you already understand and keep a backup."] },
          { heading: "Transport to accommodation", items: [arrival === "late night" ? "Favor official taxi, hotel transfer, or airport hotel over complex public transport." : "Choose the easiest door-to-door route, not only the fastest one.", "Save the address offline and keep the booking visible."] },
          { heading: "Check-in or luggage storage", items: [`Plan around check-in at ${checkin}.`, "If the room is not ready, use luggage storage if available and keep valuables with you."] },
          { heading: "Food, rest, and orientation", items: [light ? "Eat simply, hydrate, shower, charge devices, and rest." : "Eat nearby, take a short orientation walk, and avoid overloading the afternoon.", activity && !light ? "Add one light nearby activity only." : "Skip optional activities if the day feels heavy."] },
          { heading: "Prepare for next day", items: ["Check tomorrow's weather and first route.", "Set alarms, charge devices, and secure documents.", "Let the first day end early if your body asks for it."] }
        ]
      };
    }

    function buildLayover(form) {
      const length = get(form, "layoverLength");
      const connection = get(form, "connectionType");
      const baggage = get(form, "baggage");
      const energy = get(form, "energy");
      const leave = get(form, "leaveAirport");
      const need = get(form, "mainNeed");
      const traveler = get(form, "travelType");
      const short = length === "under 3 hours";
      const long = length === "6–10 hours" || length === "over 10 hours";
      const carryingBags = baggage === "carrying luggage";
      const considerLeaving = long && leave === "yes" && !carryingBags && connection !== "not sure";
      const stayInside = short || carryingBags || leave === "no" || connection === "not sure";
      return {
        title: stayInside ? "Stay inside the airport and protect your connection" : considerLeaving ? "You may consider leaving only after official checks" : "Keep the layover flexible and close to the airport",
        sections: [
          { heading: "Stay inside vs consider leaving", items: [stayInside ? "Staying inside the airport is the safer default for this layover." : "Leaving may be possible only if official transit, immigration, visa, baggage, and re-entry rules allow it.", short ? "A short layover should focus on the next gate, restroom, water, and simple food." : "Use the extra time, but keep boarding and security timing visible.", carryingBags ? "Carrying luggage makes airport exits and city visits less comfortable." : "Checked-through baggage gives you more flexibility, but rules still decide what is possible."] },
          { heading: "Good layover activities", items: [need === "rest" ? "Find a quiet gate area, lounge, sleep pod, or airport hotel option if available." : need === "food" ? "Eat a simple meal after confirming your next gate or terminal." : need === "shower" ? "Look for official lounge, transit hotel, or shower facilities before wandering." : need === "work" ? "Choose a staffed, well-lit area near power and Wi-Fi, then set a boarding alarm." : need === "walking" ? "Take a light terminal walk, but avoid leaving the secure area without official confirmation." : "Look for quiet zones, prayer rooms, lounges, libraries, or calmer gate areas if available.", traveler === "family" ? "For families, choose fewer moves and keep snacks, restrooms, and seating close." : "Set alarms for boarding, gate changes, and the time you need to start moving again."] },
          { heading: "Checks before you relax or exit", items: ["Next flight gate or terminal", "Boarding time, not only departure time", "Whether security or passport control is needed again", "Baggage status and pickup requirements", "Official immigration, visa, airline, and airport transit rules", "How long it takes to return to the gate from where you plan to wait"] },
          { heading: "Comfort tips", items: [energy === "tired" ? "Choose rest, food, hydration, and charging over sightseeing." : energy === "energetic" ? "Use energy for a controlled walk or errand, not a rushed city detour." : "Keep activity light enough that you still board calmly.", "Keep documents, wallet, phone, chargers, medication, and boarding details with you.", "Do not sleep so deeply that you miss gate changes or boarding."] },
          { heading: "Mistakes to avoid", items: ["Leaving transit because another traveler says it is fine", "Forgetting visa, immigration, or re-entry rules", "Sitting far from your gate with no alarm", "Assuming checked baggage always follows automatically", "Making a city plan that depends on perfect traffic and timing"] },
          { heading: "Layover checklist", items: ["Next gate checked", "Boarding alarm set", "Phone charged", "Food/water handled", "Baggage situation confirmed", "Official rules checked before any airport exit"] }
        ]
      };
    }

    function buildCharging(form) {
      const devices = checked(form, "devices");
      const tripType = get(form, "tripType");
      const airportWait = yes(get(form, "airportWait"));
      const powerBank = get(form, "powerBank");
      const stayType = get(form, "stayType");
      const workNeeds = get(form, "workNeeds");
      const travelers = get(form, "travelers");
      const hasLaptop = devices.includes("laptop");
      const manyTravelers = travelers === "3" || travelers === "4+";
      const must = ["Destination-compatible travel adapter", "Phone charging cable", "Wall charger", "Power bank where airline rules allow"].concat(hasLaptop ? ["Laptop charger"] : []).concat(devices.includes("camera") ? ["Camera charger or spare camera battery"] : []);
      const nice = ["Short cable for airport charging", "Cable pouch or small zip bag", "Spare cable for your main phone"].concat(manyTravelers ? ["Small multi-port charger for shared use"] : []).concat(stayType === "hostel" ? ["Longer cable for awkward outlets near bunks"] : []);
      return {
        title: "Your travel charging checklist",
        sections: [
          { heading: "Devices selected", items: devices.length ? devices : ["No devices selected yet. At minimum, plan for your phone and any device used for tickets, maps, or messages."] },
          { heading: "Must-have charging items", items: must },
          { heading: "Nice-to-have items", items: nice },
          { heading: "Carry-on essentials", items: ["Phone cable and wall charger", airportWait || powerBank !== "no" ? "Power bank in cabin baggage if airline rules allow" : "Enough phone battery for airport arrival and transport", "Any charger needed for boarding passes, maps, hotel messages, medication apps, or work", "Do not place essential charging items only in checked luggage."] },
          { heading: "Power bank reminder", items: [powerBank === "yes" || airportWait ? "Charge your power bank before departure and confirm airline capacity rules." : powerBank === "not sure" ? "A small approved power bank is useful if you depend on your phone for arrival details." : "If you skip a power bank, protect phone battery during the flight and airport wait.", "Power banks and spare lithium batteries are commonly restricted to cabin baggage; confirm rules for your airline."] },
          { heading: "Cable organization", items: ["Pack cables in one small pouch.", "Label similar cables if traveling with multiple people.", workNeeds === "heavy work" ? "Keep work chargers separate from general family chargers so one missing item does not stop work." : "Avoid packing every cable loose across different bags."] },
          { heading: "Check before departure", items: [`Confirm destination plug type and voltage for your ${tripType}.`, "Check device charger labels for voltage compatibility.", "Confirm adapter quality and fit before airport day.", "Charge phone, headphones, and power bank the night before travel."] }
        ]
      };
    }

    function buildAddressCard(form) {
      const name = get(form, "accommodationName");
      const address = get(form, "accommodationAddress");
      const phone = get(form, "phone");
      const checkin = get(form, "checkin");
      const booking = get(form, "bookingRef");
      const landmark = get(form, "landmark");
      const city = get(form, "city");
      const notes = get(form, "driverNotes");
      const emergencyName = get(form, "emergencyContactName");
      const emergencyPhone = get(form, "emergencyContactPhone");
      const optional = [
        city && `Destination city: ${city}`,
        phone && `Accommodation phone: ${phone}`,
        landmark && `Nearby landmark: ${landmark}`,
        checkin && `Check-in time: ${checkin}`,
        booking && `Booking reference: ${booking}`,
        notes && `Notes for driver/staff: ${notes}`,
        emergencyName && `Emergency contact name: ${emergencyName}`,
        emergencyPhone && `Emergency contact phone: ${emergencyPhone}`
      ].filter(Boolean);
      return {
        title: "Your airport-to-hotel address card",
        sections: [
          { heading: "Show this address if needed", items: [`Accommodation: ${name}`, `Address: ${address}`, "Show this address to official airport transport staff if needed."] },
          { heading: "Extra arrival details", items: optional.length ? optional : ["No optional details added. The accommodation name and address are enough for a simple card."] },
          { heading: "Use it safely", items: ["Copy, screenshot, or print this card before travel.", "Keep the card private when you no longer need to show it.", "Avoid adding passport, payment, or sensitive personal details.", "Confirm the address and entrance with your accommodation before departure."] }
        ]
      };
    }

    function buildConfidence(form) {
      const selected = checked(form, "readiness");
      const all = Array.from(form.querySelectorAll('input[name="readiness"]')).map((input) => input.value);
      const missing = all.filter((item) => !selected.includes(item));
      const score = Math.round((selected.length / all.length) * 100);
      const status = score >= 85 ? "Ready" : score >= 60 ? "Almost Ready" : "Needs More Preparation";
      const priorityOrder = ["Passport checked", "Visa/ETA/entry rule checked", "Flight details saved", "Accommodation confirmed", "Airport transport planned", "Travel documents saved offline", "Money plan ready", "Internet plan ready", "Emergency contacts saved", "Important medication packed", "Phone charger and adapter packed", "First-day plan prepared", "Travel insurance considered", "Local customs reviewed"];
      const priorities = priorityOrder.filter((item) => missing.includes(item)).slice(0, 5);
      return {
        title: `${status}: ${score}/100 travel readiness score`,
        sections: [
          { heading: "Readiness result", items: [`Status: ${status}`, `Score: ${score}/100`, score >= 85 ? "Your basics look strong. Use the final days to confirm official details and keep copies accessible." : score >= 60 ? "You have a good base, but a few missing items could create airport or arrival stress." : "Focus on the essentials before adding optional trip details."] },
          { heading: "Completed items", items: selected.length ? selected : ["No completed items selected yet."] },
          { heading: "Missing items", items: missing.length ? missing : ["Everything in this checklist is selected. Review official requirements again close to departure."] },
          { heading: "Priority actions", items: priorities.length ? priorities.map((item) => `Handle: ${item}`) : ["Confirm passport, entry rules, flight, accommodation, transport, money, internet, and offline documents shortly before travel."] },
          { heading: "First-day advice", items: ["Keep the first day simple: airport exit, phone connection, money/payment, official transport, check-in, food, water, rest.", "Confirm official visa, entry, transit, health, and immigration requirements for your nationality and route.", "Save important details offline before leaving for the airport."] }
        ]
      };
    }

    function buildWalking(form) {
      const distance = get(form, "distance");
      const luggage = get(form, "luggage");
      const time = get(form, "arrivalTime");
      const weather = get(form, "weather");
      const traveler = get(form, "travelerType");
      const energy = get(form, "energy");
      const familiarity = get(form, "familiarity");
      let risk = 0;
      if (distance === "500m–1km") risk += 1;
      if (distance === "1–2km") risk += 2;
      if (distance === "over 2km") risk += 4;
      if (luggage === "small suitcase") risk += 1;
      if (luggage === "large suitcase") risk += 2;
      if (luggage === "multiple bags") risk += 3;
      if (time === "evening") risk += 1;
      if (time === "late night") risk += 3;
      if (weather !== "normal") risk += weather === "not sure" ? 1 : 2;
      if (traveler === "family" || traveler === "senior traveler") risk += 1;
      if (energy === "low") risk += 2;
      if (energy === "high") risk -= 1;
      if (familiarity !== "know the area") risk += 1;
      const recommendation = risk <= 3 ? "Walking seems reasonable" : risk <= 7 ? "Consider transport" : "Avoid walking if possible";
      return {
        title: recommendation,
        sections: [
          { heading: "Recommendation", items: [recommendation, risk <= 3 ? "Your plan looks manageable if the actual route has sidewalks, safe crossings, and a clear entrance." : risk <= 7 ? "The walk may work, but luggage, timing, weather, or unfamiliarity make a backup transport option sensible." : "The walk has enough friction that verified transport is likely the calmer arrival-day choice."] },
          { heading: "Why this result fits", items: [`Distance: ${distance}`, `Luggage: ${luggage}`, `Time: ${time}`, `Weather/conditions: ${weather}`, `Energy: ${energy}`, familiarity === "know the area" ? "The area is familiar, which makes walking easier." : "An unfamiliar final route makes small problems harder while carrying bags."] },
          { heading: "Luggage comfort", items: [luggage === "multiple bags" ? "Multiple bags make stairs, curbs, rain, and crowds much harder." : luggage === "large suitcase" ? "A large suitcase can turn a short route into a tiring route if there are stairs or rough pavements." : luggage === "small suitcase" ? "A small suitcase is manageable on smooth, flat, short routes." : "A backpack gives you the most walking flexibility.", "Check for elevators, escalators, cobblestones, steep streets, and station exits before deciding."] },
          { heading: "Safety reminders", items: ["Keep the tone practical: the goal is comfort and clarity, not fear.", "Avoid walking while distracted by a phone at the roadside.", "If the route feels wrong, move to a staffed public place and choose transport.", time === "late night" ? "Late-night walks should be short, clear, and well lit; otherwise use verified transport." : "Daytime still deserves route checking when you are tired or carrying bags."] },
          { heading: "Checks before walking", items: ["Exact entrance saved", "Offline map available", "Phone battery enough", "Weather checked", "Route lighting and sidewalks reviewed", "One backup transport option known"] },
          { heading: "Alternatives", items: ["Official taxi for the final leg", "Ride-hailing from a signed pickup area", "One more public transport stop if it reduces walking", "Hotel transfer or staffed transport desk", "Luggage storage before exploring"] }
        ]
      };
    }

    const builders = { first24: buildFirst24, transport: buildTransport, internet: buildInternet, documents: buildDocuments, money: buildMoney, lateNight: buildLateNight, packing: buildPacking, itinerary: buildItinerary, layover: buildLayover, charging: buildCharging, addressCard: buildAddressCard, confidence: buildConfidence, walking: buildWalking };
    document.querySelectorAll(".tool-form").forEach((form) => {
      const resultEl = form.closest(".tool-card").querySelector("[data-result]");
      const messageEl = form.querySelector("[data-form-message]");
      form.addEventListener("submit", (event) => {
        event.preventDefault();
        messageEl.textContent = "";
        const invalid = Array.from(form.querySelectorAll("[required]")).find((field) => !field.value.trim());
        if (invalid) {
          messageEl.textContent = "Please complete the required fields before generating a result.";
          invalid.focus();
          return;
        }
        const output = builders[form.dataset.toolType](form);
        render(resultEl, output.title, output.sections);
      });
      form.querySelector("[data-copy-result]")?.addEventListener("click", async () => {
        const text = resultEl.dataset.resultText || "";
        if (!text) {
          messageEl.textContent = "Generate a result first, then copy it.";
          return;
        }
        try {
          await navigator.clipboard.writeText(text);
          messageEl.textContent = "Copied to clipboard.";
        } catch {
          messageEl.textContent = "Copy was not available on this device. You can select the result text manually.";
        }
      });
      form.querySelector("[data-print-result]")?.addEventListener("click", () => {
        if (!resultEl.dataset.resultText) {
          messageEl.textContent = "Generate a checklist first, then print it.";
          return;
        }
        window.print();
      });
      form.addEventListener("reset", () => {
        setTimeout(() => {
          messageEl.textContent = "";
          resultEl.dataset.resultText = "";
          resultEl.innerHTML = "<h3>Your travel planning suggestion</h3><p>Choose your options and use the result as a simple starting point for your travel planning.</p>";
        }, 0);
      });
    });
  </script>
</BaseLayout>
