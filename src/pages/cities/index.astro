---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GuideCard from "../../components/GuideCard.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SectionFilter from "../../components/SectionFilter.astro";
import { cityGuides } from "../../data/site";
---
<BaseLayout title="City Arrival Guides | EZ Roam Guide" description="Browse city arrival guides for airport transfers, local transport, money, internet, food, safety, and a simple first-day plan.">
  <Breadcrumb items={[{label:"Home",href:"/"},{label:"Cities"}]} />
  <header class="page-head"><div class="container"><p class="eyebrow">City guides</p><h1>Get from arrivals to settled</h1><p class="lede">City-level advice for the details that matter immediately: which airport you used, how to reach your district, and how to make the first evening easy.</p></div></header>
  <section class="section"><div class="container">
    <SectionFilter targetId="city-guide-list" label="Filter this section" placeholder="Filter city guides by city or topic" noResults="No city guide matches yet. Try a broader word such as airport, transport, late night, or money." />
    <div id="city-guide-list" class="card-grid" data-filter-scope>{cityGuides.map((guide) => <GuideCard guide={guide} />)}</div>
  </div></section>
</BaseLayout>
