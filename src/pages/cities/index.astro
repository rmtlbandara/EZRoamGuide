---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GuideCard from "../../components/GuideCard.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SectionFilter from "../../components/SectionFilter.astro";
import { cityGuides } from "../../data/site";
import { absoluteUrl, breadcrumbListSchema, webPageSchema } from "../../data/schema";

const title = "City Arrival Guides | EZ Roam Guide";
const description = "Browse city arrival guides for airport transfers, local transport, money, internet, food, safety, and a simple first-day plan.";
const breadcrumbSchema = breadcrumbListSchema([
  { name: "Home", url: absoluteUrl("/") },
  { name: "Cities", url: absoluteUrl("/cities/") }
]);
const pageSchema = webPageSchema("City Arrival Guides", description, "/cities/");
---
<BaseLayout title={title} description={description} schema={[breadcrumbSchema, pageSchema]}>
  <Breadcrumb items={[{label:"Home",href:"/"},{label:"Cities"}]} />
  <header class="page-head"><div class="container"><p class="eyebrow">City guides</p><h1>Get from arrivals to settled</h1><p class="lede">City-level advice for the details that matter immediately: which airport you used, how to reach your district, and how to make the first evening easy.</p></div></header>
  <section class="section alt">
    <div class="container feature-grid">
      <div>
        <p class="eyebrow">How to use city guides</p>
        <h2>Turn airport arrival into a simple route</h2>
      </div>
      <div>
        <p>City guides focus on the first few practical decisions after landing: the airport or terminal you used, the best type of transfer, where to stay first, how to get connected, and what to keep light on arrival day.</p>
        <p>Use them after a country guide when you need local airport, neighborhood, transport, and first-night context.</p>
        <div class="actions">
          <a class="button secondary" href="/countries/">Browse country guides</a>
          <a class="button secondary" href="/travel-basics/best-airport-transport-new-country/">Choose airport transport</a>
          <a class="button secondary" href="/tools/airport-transport-helper/">Use the transport helper</a>
        </div>
      </div>
    </div>
  </section>
  <section class="section"><div class="container">
    <SectionFilter targetId="city-guide-list" label="Filter this section" placeholder="Filter city guides by city or topic" noResults="No city guide matches yet. Try a broader word such as airport, transport, late night, or money." />
    <div id="city-guide-list" class="card-grid" data-filter-scope>{cityGuides.map((guide) => <GuideCard guide={guide} />)}</div>
  </div></section>
  <section class="section alt">
    <div class="container feature-grid">
      <div><p class="eyebrow">Arrival planning clusters</p><h2>Support your city plan with practical basics</h2></div>
      <div class="related">
        <a href="/travel-basics/arriving-late-at-night/"><span>Prepare for a late-night arrival →</span><small>Safety, check-in, and transport</small></a>
        <a href="/travel-basics/how-to-use-public-transport-abroad/"><span>Use public transport abroad with less stress →</span><small>Tickets, routes, and transfers</small></a>
        <a href="/travel-basics/first-night-abroad-where-to-stay/"><span>Choose your first-night stay area →</span><small>First-night stay and local basics</small></a>
        <a href="/tools/first-24-hours-travel-planner/"><span>Build a simple first-day plan →</span><small>Free arrival planning tool</small></a>
      </div>
    </div>
  </section>
</BaseLayout>
