---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  type?: "website" | "article";
  schema?: object | object[];
}
const { title, description, canonical = Astro.url.pathname, type = "website", schema } = Astro.props;
const canonicalUrl = new URL(canonical, site.url).toString();
const schemas = Array.isArray(schema) ? schema : schema ? [schema] : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#087f6b" />
    <meta name="generator" content={Astro.generator} />
    {schemas.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NTP076LHCW"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NTP076LHCW');
    </script>
  </head>
  <body>
    <Header />
    <main id="main-content"><slot /></main>
    <Footer />
  </body>
</html>
